# INSURE.AI — Environment Variables
# Copy to .env and fill in values

# ── ANTHROPIC ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── AGENT BACKEND ─────────────────────────────────────────────────────────────
AGENT_BASE_URL=http://localhost:8000

# ── CRM / POLICY / CLAIMS SYSTEMS ─────────────────────────────────────────────
# Replace with your actual endpoints (or mock server during dev)
CRM_BASE_URL=http://localhost:9001
POLICY_BASE_URL=http://localhost:9002
PRODUCT_BASE_URL=http://localhost:9003
AUDIT_BASE_URL=http://localhost:9004

# ── DATABASE (Phase 2: PostgreSQL) ────────────────────────────────────────────
# DATABASE_URL=postgresql://insureai:password@localhost:5432/insureai

# ── n8n ───────────────────────────────────────────────────────────────────────
# N8N_WEBHOOK_BASE_URL=https://your-n8n-instance.app.n8n.cloud
# N8N_API_KEY=...

# ── DEPLOYMENT (Phase 3) ──────────────────────────────────────────────────────
# SERVER_HOST=0.0.0.0
# SERVER_PORT=8000
# ENVIRONMENT=production
